{
  "schemaVersion": 1,
  "id": "minecraft-cursor",
  "version": "${version}",
  "name": "Minecraft Cursor",
  "description": "Configurable cursor for Minecraft",
  "authors": [
    "fishstiz"
  ],
  "contributors": [
    "demorogabrtz",
    "Lucanoria"
  ],
  "contact": {
    "sources": "https://github.com/fishstiz/minecraft-cursor",
    "issues": "https://github.com/fishstiz/minecraft-cursor/issues"
  },
  "license": "MIT",
  "icon": "icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "io.github.fishstiz.minecraftcursor.MinecraftCursorFabric"
    ],
    "modmenu": [
      "io.github.fishstiz.minecraftcursor.impl.MinecraftCursorModMenuApiImpl"
    ],
    "minecraft-cursor": [
      "io.github.fishstiz.minecraftcursor.impl.MinecraftCursorFabricInitializer"
    ]
  },
  "mixins": [
    {
      "config": "minecraft-cursor.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.16.9",
    "minecraft": ">=1.21.4",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "modmenu": "*"
  }
}